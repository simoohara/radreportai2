# Cloudflare Workers local environment variables
# Copy this file to .dev.vars and fill in your values.

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT signing secret (generate a random 64-char string)
JWT_SECRET=change-me-to-a-random-64-character-string

# Gemini API key
API_KEY=your-gemini-api-key

# App URL (for OAuth redirects)
APP_URL=http://localhost:5173

# Optional: Analytics
# FACEBOOK_PIXEL_ID=
# GA_MEASUREMENT_ID=
